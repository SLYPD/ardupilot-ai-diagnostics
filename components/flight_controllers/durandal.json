{
  "flight_controller": {
    "model": "Holybro Durandal",
    "mcu": "STM32H743",
    "firmware": "ArduPilot (Copter)",
    "imu": [
      { "id": "IMU1", "chip": "InvenSense ICM-42688-P", "isolated": true },
      { "id": "IMU2", "chip": "Bosch BMI088", "isolated": false }
    ],
    "barometer": "MS5611",
    "power_module": "Holybro PM07",
    "telemetry_radio": "Holybro SiK Telemetry Radio V3"
  },
  "power_system": {
    "vcc": {
      "description": "Flight controller 5V rail",
      "min_v": 4.8,
      "max_v": 5.3,
      "max_fluctuation_v": 0.15
    }
  },
  "thresholds": {
    "vibration": {
      "xy_max_m_s2": 30.0,
      "z_max_m_s2": 45.0
    },
    "imu_clipping": {
      "max_clip_count": 0,
      "description": "Any VIBE.Clip value greater than 0 indicates mechanical shock or IMU sensor saturation."
    }
  }
}
